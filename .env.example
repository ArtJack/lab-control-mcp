# Copy to .env and fill in. .env is git-ignored.

# LiteLLM gateway (the lab's front door). Key lives in /opt/ai-lab/.env on the Alienware.
LITELLM_BASE_URL=http://192.168.1.159:4000
LITELLM_BASE_URL_TS=http://100.66.124.80:4000
LITELLM_MASTER_KEY=

# Ollama endpoints
OLLAMA_M4=http://127.0.0.1:11434
OLLAMA_GTX=http://192.168.1.159:11434

# Qdrant
QDRANT_URL=http://192.168.1.159:6333
QDRANT_API_KEY=

# Ops targets
LABCTL_ALIENWARE_SSH=alienware
LABCTL_LAB_DIR=/Users/artjack/Projects/AI/projects/local-agent-lab

# run_command allowlist — comma-separated EXTRA command prefixes to permit
# (the curated read-mostly defaults in config.py are always allowed).
# Suggested "operate the lab" set (safe, reachable, no shell-escapes):
#   launchctl list,launchctl kickstart,launchctl start,launchctl stop,ollama rm,ollama cp,
#   git push,git add,git commit,git checkout,git switch,git diff,git show,git stash,git restore,
#   tailscale status,tailscale ping,tailscale ip,tailscale netcheck,lsof,dig,nslookup,
#   brew list,brew info,brew services list,tasklist,ipconfig
# Do NOT add interpreters/exec-wrappers (python -c, uv run, ssh, bash/sh, docker exec/run, wsl -d/-e).
LABCTL_ALLOWED_COMMANDS=

# MCP transport (the server itself)
LABCTL_MCP_TRANSPORT=stdio
LABCTL_MCP_HOST=127.0.0.1
LABCTL_MCP_PORT=8849
LABCTL_MCP_TOKEN=
# LABCTL_MCP_ALLOWED_HOSTS=my-host.tailnet.ts.net:8849
